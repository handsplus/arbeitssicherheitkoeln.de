{
  "name": "arbeitssicherheit-koeln",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node ./node_modules/next/dist/bin/next dev",
    "dev:turbo": "node ./node_modules/next/dist/bin/next dev --turbo",
    "clean": "node scripts/clean-next.cjs",
    "dev:fresh": "node scripts/clean-next.cjs && node ./node_modules/next/dist/bin/next dev",
    "prebuild": "node ./node_modules/tsx/dist/cli.mjs scripts/generate-feed.ts",
    "build": "node scripts/run-export-build.cjs",
    "start": "node ./node_modules/next/dist/bin/next start",
    "start:3001": "node ./node_modules/next/dist/bin/next start -p 3001",
    "serve": "npx --yes serve out -l 3001",
    "lint": "node ./node_modules/next/dist/bin/next lint"
  },
  "dependencies": {
    "next": "^14.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0",
    "to-ico": "^1.1.5",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0"
  }
}
